# ======================== 必填：Hydro 连接信息 ========================

# Hydro 站点地址。建议保留末尾 /；遗漏时启动脚本会自动补全。
HYDRO_SERVER_URL=https://oj.example.com/

# 拥有 PRIV_JUDGE 权限的专用评测账号。
HYDRO_JUDGE_UNAME=judge

# 请务必修改示例密码。单引号可避免 $、# 等字符被 Compose 展开；
# 如果密码本身包含单引号，请写成 \'。
HYDRO_JUDGE_PASSWORD='change_me'

# 普通 Hydro 使用 hydro；仅连接 vj4 服务时改为 vj4。
HYDRO_HOST_TYPE=hydro

# ======================== 基础运行设置 ========================

# 容器时区。
TZ=Asia/Shanghai

# Compose 项目名决定容器、网络和数据卷前缀。安装后不要随意修改。
COMPOSE_PROJECT_NAME=hydrojudge-docker

# 固定的运行时版本。请通过 update-version 更新，不要直接改版本号后运行 update-config。
GOJUDGE_VERSION=v1.12.1
HYDROJUDGE_VERSION=4.0.5

# Ubuntu 软件源。国内默认使用清华镜像；海外可改为 http://archive.ubuntu.com/ubuntu。
UBUNTU_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/ubuntu

# npm 软件源。国内默认使用 npmmirror；海外可改为 https://registry.npmjs.org。
NPM_REGISTRY=https://registry.npmmirror.com

# 首次启动或手动执行 ./scale.sh 时使用的副本数。
WORKER_REPLICAS=1

# ======================== 宿主机自动扩容 ========================

# 自动扩容只增加副本，不会自动缩容，以免中断正在执行的评测任务。
AUTOSCALE_MIN_REPLICAS=1
AUTOSCALE_MAX_REPLICAS=4
AUTOSCALE_TARGET_CPU_PERCENT=50
AUTOSCALE_TARGET_MEMORY_PERCENT=50
AUTOSCALE_SCALE_UP_SAMPLES=2
AUTOSCALE_INTERVAL_SECONDS=5
AUTOSCALE_COOLDOWN_SECONDS=10
AUTOSCALE_MAX_STEP=1
AUTOSCALE_ENFORCE_HOST_CAPACITY=true
AUTOSCALE_HOST_HEADROOM_PERCENT=10
AUTOSCALE_DRY_RUN=false

# ======================== 单个 Docker 容器上限 ========================

CONTAINER_CPUS=4.0
CONTAINER_MEMORY_LIMIT=12g

# 与内存上限相同表示禁用额外交换空间；-1 表示不限制交换空间（通常不建议）。
CONTAINER_MEMORY_SWAP_LIMIT=12g
CONTAINER_SHM_SIZE=2g

# ======================== HydroJudge 执行限制 ========================

# 应为沙箱、Node.js、输出缓冲区和编译进程预留资源。
HYDRO_MEMORY_MAX=2048m
HYDRO_STDIO_SIZE=256m
HYDRO_STRICT_MEMORY=false
HYDRO_TESTCASES_MAX=450
HYDRO_TOTAL_TIME_LIMIT=3000
HYDRO_PROCESS_LIMIT=32
HYDRO_PARALLELISM=3
HYDRO_CONCURRENCY=3
HYDRO_DETAIL=full
HYDRO_RERUN=1
HYDRO_PERFORMANCE=true
HYDRO_SANDBOX_HOST=http://127.0.0.1:5050

# ======================== go-judge 沙箱设置 ========================

GOJUDGE_HTTP_ADDR=127.0.0.1:5050
GOJUDGE_PARALLELISM=3
GOJUDGE_OUTPUT_LIMIT=256m
GOJUDGE_COPY_OUT_LIMIT=256m
GOJUDGE_FILE_TIMEOUT=30m
