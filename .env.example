# Hydro site URL. Keep the trailing slash. entrypoint.sh also auto-adds it if omitted.
HYDRO_SERVER_URL=https://oj.example.com/

# Judge account that has PRIV_JUDGE permission in Hydro.
HYDRO_JUDGE_UNAME=judge
HYDRO_JUDGE_PASSWORD=change_me

# Usually keep this as hydro. Use vj4 only if connecting to a vj4 server.
HYDRO_HOST_TYPE=hydro

# Container timezone.
TZ=Asia/Kuala_Lumpur

# Pinned runtime versions. Update these deliberately, then rebuild the image.
GOJUDGE_VERSION=v1.12.1
HYDROJUDGE_VERSION=4.0.5
WORKER_REPLICAS=1

# Host-side automatic scale-up. It never scales down running workers automatically.
AUTOSCALE_MIN_REPLICAS=1
AUTOSCALE_MAX_REPLICAS=4
AUTOSCALE_TARGET_CPU_PERCENT=70
AUTOSCALE_TARGET_MEMORY_PERCENT=70
AUTOSCALE_SCALE_UP_SAMPLES=2
AUTOSCALE_INTERVAL_SECONDS=15
AUTOSCALE_COOLDOWN_SECONDS=60
AUTOSCALE_MAX_STEP=1
AUTOSCALE_ENFORCE_HOST_CAPACITY=true
AUTOSCALE_HOST_HEADROOM_PERCENT=10
AUTOSCALE_DRY_RUN=false

# Outer Docker container limits.
CONTAINER_CPUS=4.0
CONTAINER_MEMORY_LIMIT=8g
CONTAINER_MEMORY_SWAP_LIMIT=8g
CONTAINER_SHM_SIZE=2g

# HydroJudge execution limits.
# Leave headroom for the sandbox, Node.js, output buffers and compiler processes.
HYDRO_MEMORY_MAX=2048m
HYDRO_STDIO_SIZE=256m
HYDRO_STRICT_MEMORY=false
HYDRO_TESTCASES_MAX=450
HYDRO_TOTAL_TIME_LIMIT=3000
HYDRO_PROCESS_LIMIT=32
HYDRO_PARALLELISM=3
HYDRO_CONCURRENCY=3
HYDRO_DETAIL=full
HYDRO_RERUN=1
HYDRO_PERFORMANCE=true
HYDRO_SANDBOX_HOST=http://127.0.0.1:5050

# go-judge limits.
GOJUDGE_HTTP_ADDR=127.0.0.1:5050
GOJUDGE_PARALLELISM=3
GOJUDGE_OUTPUT_LIMIT=256m
GOJUDGE_COPY_OUT_LIMIT=256m
GOJUDGE_FILE_TIMEOUT=30m
